# Docker-compose env_file for the sim-in-the-loop lane.
# Plain KEY=VALUE (no `export`, no shell expansion) — the shell version with
# rationale lives in strafer_bringup/config/env_sim_in_the_loop.env; keep the
# two in sync. CYCLONEDDS_URI points at the file bind-mounted by compose.

RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
CYCLONEDDS_URI=file:///opt/strafer/config/cyclonedds.xml
ROS_DOMAIN_ID=42

# Skip real-hardware watchdogs (no USB bus in the sim lane)
HARDWARE_PRESENT=false

# Sim-rate freshness tunings (bridge publishes slower than real hardware)
OBSERVATION_MAX_AGE_S=2.0
STRAFER_OBS_TIMEOUT_S=1.0
STRAFER_DEPTH_TIMEOUT_S=2.0
ROTATE_TIMEOUT_S=60.0
STRAFER_PROJECTION_DEPTH_MAX_M=15.0
STRAFER_NAVIGATION_TIMEOUT_S=180.0

# navigate_to_pose backend: nav2 launches NEITHER inference node (no GPU needed).
# Switch to strafer_direct / hybrid_nav2_strafer + set STRAFER_INFERENCE_MODEL_PATH
# to exercise the policy (needs the strafer-gpu image).
STRAFER_NAV_BACKEND=nav2
STRAFER_INFERENCE_MODEL_PATH=
STRAFER_POLICY_VARIANT=DEPTH

# Remote VLM / planner services on the sim host. Only contacted when a mission
# is dispatched; point these at wherever your Isaac Sim host runs them.
VLM_URL=http://192.168.50.196:8100
PLANNER_URL=http://192.168.50.196:8200
