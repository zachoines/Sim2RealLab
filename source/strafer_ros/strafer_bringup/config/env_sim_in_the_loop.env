# Environment for sim-in-the-loop operation.
#
# Source this file on the Jetson before launching
# `bringup_sim_in_the_loop.launch.py`. The DGX Spark must export the
# same `RMW_IMPLEMENTATION` and `ROS_DOMAIN_ID` from its `env_setup.sh`
# so the ROS2 middleware discovers the bridge across the LAN.
#
# LAN topology (Phase 15):
#   DGX Spark          : 192.168.50.196 (hostname dgx-spark)
#   Jetson Orin Nano   : 192.168.50.24  (hostname jetson-desktop)
#
# Both hosts must be on the same LAN subnet.
#
# Deferred: Isaac Sim 4.x has no `ROS2PublishImu` OmniGraph node, so the
# DGX bridge does not publish `/d555/imu`. RTAB-Map is configured to run
# in visual-only mode in this launch variant; do not expect IMU data
# until the sim bridge grows IMU publishing.

# Cyclone DDS is chosen for reliable cross-host discovery; FastDDS's
# default shared-memory transport does not span machines without
# extensive tuning.
export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# Any value works as long as both hosts agree. 42 is arbitrary.
export ROS_DOMAIN_ID=42

# Tells launch files (and the executor startup) to skip real-hardware
# watchdogs that would false-positive without the USB bus.
export HARDWARE_PRESENT=false

# Widen the cached-frame freshness cap — the DGX bridge currently
# publishes at ~5 Hz (200 ms period), so the real-robot default of
# 0.5 s offers only 2.5 frames of headroom and trips on minor jitter.
# 2.0 s is still tight enough to catch a genuinely stalled perception
# stack.
export OBSERVATION_MAX_AGE_S=2.0

# scan_for_target calls rotate_in_place without an explicit timeout
# and falls back to this default. The real-robot default (15 s) is
# cut for 30 Hz control on the Jetson; Isaac Sim's sub-unity RTF plus
# slow wheel-contact dynamics push each in-place rotation well past
# that. 60 s keeps scans viable while still catching a genuinely
# stuck rotation controller.
export ROTATE_TIMEOUT_S=60.0

# Lift Nav2's velocity caps to the chassis maximum for sim missions.
# The constants default (NAV_VEL_SCALE=0.5) is an indoor safety bound
# for the real robot — there's no equivalent collision risk in sim, and
# at 0.5 MPPI tops out at ~0.78 m/s while joystick teleop and the
# trained policy can reach ~1.57 m/s, which biases MPPI toward
# conservative commands. 1.0 lets MPPI ask for the full envelope.
export STRAFER_NAV_VEL_SCALE=1.0

# Widen goal-projection's max-depth cutoff for sim missions. The default
# (6.0 m, set in goal_projection_node._DEPTH_MAX_M) is a conservative
# bound on the real D555's stereo noise floor — beyond it, real-camera
# depth gets unreliable. Isaac Sim renders perpendicular-to-image-plane
# depth accurately out to D555_RENDER_FAR_CLIP_M=50 m, so the real-D555
# bound rejects valid sim depths and trips
# `goal_projection_failed: out of range` on every VLM target across a
# room, hallway, or doorway. 15 m admits cross-room targets while
# leaving the (separate) 6 m policy / Nav2 normalization cap in
# strafer_shared.constants untouched. Real-robot bringup leaves this
# unset and keeps the 6 m default. See
# docs/tasks/completed/goal-projection-depth-range.md.
#
# DISABLED 2026-04-28 pending docs/tasks/nav2-far-goal-staging.md.
# End-to-end testing on 2026-04-27 found that admitting projected goals
# past 6 m surfaced a downstream Nav2 failure: the global costmap is
# bounded by /rtabmap/map (which itself caps at RTAB-Map's
# Grid/RangeMax=6.0 m), so goals past the SLAM horizon land off the
# costmap and the planner aborts with "goal off the global costmap".
# Re-enable this export as part of the staging-task acceptance bullet
# once the executor handles off-costmap goals via reactive staging.
# export STRAFER_PROJECTION_DEPTH_MAX_M=15.0

# The executor's nav timeout now ticks on the executor node's clock, so
# under use_sim_time:=true a 90 s budget is a sim-time budget. With the
# bridge unit-mismatch fix (Nav2 cmd_vel no longer over-amplified) and
# STRAFER_NAV_VEL_SCALE=1.0 above, MPPI commands match sim reality and
# missions cover ground at chassis-max speeds in sim time. 180 s gives
# multi-room missions enough sim-time headroom while staying short
# enough that genuine controller wedges fail visibly. Raise toward the
# previous 600 s if the DGX bridge regresses to sub-unity RTF without
# a corresponding velocity scale fix.
export STRAFER_NAVIGATION_TIMEOUT_S=180.0
