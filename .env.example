# Sim2RealLab — per-machine environment configuration.
#
# Copy this file to `.env` at the repo root and fill in the paths for your
# host. `.env` is gitignored (never committed); this template IS committed
# and documents every variable the repo reads.
#
#     cp .env.example .env
#     $EDITOR .env
#     source env_setup.sh
#
# Single delivery mechanism: `env_setup.sh` sources this file into the
# current shell so every subprocess child (pytest, python, isaaclab.sh,
# make, ...) inherits the variables. Python code reads values via
# `os.environ` — there is no Python-side `.env` parser. If a script errors
# with "STRAFER_BLENDER_BIN is not set", you forgot `source env_setup.sh`
# at the start of the shell session.
#
# Tests that need to override these values use `pytest monkeypatch.setenv`
# and do not touch the real `.env` file.

# ---------------------------------------------------------------------------
# Repo roots
# ---------------------------------------------------------------------------

# Absolute path to this checkout. Used by a handful of shell helpers and
# documented in docs/PHASE_15_DGX.md §9.
STRAFER_ROOT=/home/you/Workspace/Sim2RealLab

# ---------------------------------------------------------------------------
# Blender 4.2 — required by Infinigen's bpy==4.2.0 pin
# ---------------------------------------------------------------------------
#
# Ubuntu 24.04 aarch64 ships Blender 4.0.2 via apt, which Infinigen will
# refuse at generation time. Build Blender 4.2 from source on aarch64 per
# `blender-build/README.md` (or delegate the build to a fresh Claude Code
# session using the prompt in the phase_15 devlog).
#
# `prep_room_usds.py` reads this variable via `_resolve_blender_binary()`.
# If it is unset AND cannot be read from this .env file, the script fails
# loud rather than silently falling back to the wrong Blender.

STRAFER_BLENDER_BIN=/home/you/Workspace/blender-build/build_blender/bin/blender

# ---------------------------------------------------------------------------
# Infinigen checkout (PHASE_15_DGX.md §6)
# ---------------------------------------------------------------------------
#
# Infinigen's `launch_blender.py` hardcodes `<root>/blender/blender` as the
# Blender binary lookup path. `env_setup.sh` creates that symlink for you
# pointing at `STRAFER_BLENDER_BIN`'s parent directory.

INFINIGEN_ROOT=/home/you/Workspace/infinigen

# ---------------------------------------------------------------------------
# Isaac Sim source build (PHASE_15_DGX.md §7)
# ---------------------------------------------------------------------------
#
# Release directory produced by `IsaacSim/build.sh`. Isaac Lab's `_isaac_sim`
# symlink and this variable should agree.

ISAACSIM_PATH=/home/you/Workspace/IsaacSim/_build/linux-aarch64/release

# ---------------------------------------------------------------------------
# HuggingFace model cache
# ---------------------------------------------------------------------------

HF_HOME=/home/you/.cache/huggingface

# ---------------------------------------------------------------------------
# Shell-only (NOT read from Python) — enforced by env_setup.sh on aarch64
# ---------------------------------------------------------------------------
#
# LD_PRELOAD is read by the dynamic loader at process start, before Python
# executes. Python code cannot effectively set LD_PRELOAD for itself; it
# must live at the shell level. `env_setup.sh` handles this automatically
# on aarch64 hosts by prepending `/lib/aarch64-linux-gnu/libgomp.so.1` to
# LD_PRELOAD whenever the host arch is `aarch64` or `arm64`. You do not
# need to set anything here — it is documented only so the behavior is
# discoverable.
