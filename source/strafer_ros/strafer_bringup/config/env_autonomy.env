# Environment for real-robot autonomy operation.
#
# Source this file for a bare-metal `autonomy.launch.py` run. (The containerized
# `make launch-autonomy` does NOT source it — the compose lane reads the generated
# deploy/compose/autonomy.env, derived from this file.) It carries the
# "set once" knobs the bringup reads from os.environ at launch time; the
# VLM/planner service URLs (VLM_URL / PLANNER_URL) stay host-specific and
# are exported by the operator, not pinned here.

# Cyclone receive-side tuning (config/cyclonedds.xml beside this file): a
# larger receive socket buffer + fragment-reassembly headroom so large
# fragmented depth frames are not dropped at the receiver under load.
# Self-locating so it works from any checkout path. REQUIRES raising
# net.core.rmem_max (config/99-cyclonedds-rmem.conf) or the 16 MB request is
# silently clamped to the ~208 KB kernel default and the tuning is inert.
# Takes effect only when RMW_IMPLEMENTATION=rmw_cyclonedds_cpp (the real
# robot's .env sets this); a no-op under any other RMW.
export CYCLONEDDS_URI="file://$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)/cyclonedds.xml"

# navigate_to_pose backend — drives BOTH the executor dispatch AND which
# inference nodes the bringup auto-launches:
#   nav2                -> Nav2 only (default; launches NEITHER inference node)
#   strafer_direct      -> + strafer_inference (RL local control)
#   hybrid_nav2_strafer -> + strafer_inference + strafer_subgoal_generator
export STRAFER_NAV_BACKEND=nav2
# Path to the exported policy artifact. EMPTY = no policy: the inference
# node refuses to advertise and missions silently fall back to nav2. A
# hybrid/strafer_direct launch with this empty is a misconfiguration.
export STRAFER_INFERENCE_MODEL_PATH=""
# PolicyVariant name for the chosen backend:
#   strafer_direct      -> DEPTH (perception) or NOCAM (no camera; unsafe)
#   hybrid_nav2_strafer -> NOCAM_SUBGOAL (costmap-trusting) or DEPTH_SUBGOAL
#                          (perception restores late-obstacle avoidance)
export STRAFER_POLICY_VARIANT=DEPTH
