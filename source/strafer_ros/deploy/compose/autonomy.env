# Autonomy knobs for the on-robot deploy lane (docker-compose.yml).
# Plain KEY=VALUE (no export). DDS vars (RMW/CYCLONEDDS/DOMAIN) come from the
# compose x-dds-env anchor; this file carries only the autonomy-specific knobs.
# Overlapping keys are pinned to canon (strafer_bringup/config/env_autonomy.env)
# by deploy/tests/check_env_sync.py -- update both or the test fails.

# navigate_to_pose backend:
#   nav2                -> Nav2 only (no inference container)
#   strafer_direct      -> + inference container (compose --profile policy)
#   hybrid_nav2_strafer -> + inference container + rolling-subgoal generator
# hybrid_nav2_strafer is the ONLY backend the depth policy runs under.
# Variant <-> backend pairing:
#   strafer_direct      -> DEPTH (perception) or NOCAM (no camera; unsafe)
#   hybrid_nav2_strafer -> NOCAM_SUBGOAL (costmap-trusting) or DEPTH_SUBGOAL
#                          (perception restores late-obstacle avoidance)
STRAFER_NAV_BACKEND=nav2

# Exported policy artifact. EMPTY = no policy: under a policy backend the
# inference launch REFUSES TO START (fail loud) rather than silently degrade to
# nav2. Mount the model under /models and set this (e.g. /models/policy.onnx).
STRAFER_INFERENCE_MODEL_PATH=
STRAFER_POLICY_VARIANT=DEPTH

# Remote VLM / planner services -- set to your real hosts. Empty here means the
# executor's startup health-check fails (by design) until they're set.
VLM_URL=
PLANNER_URL=

# REAL-HARDWARE GUARD: do NOT add STRAFER_DEPTH_TIMEOUT_S / STRAFER_OBS_TIMEOUT_S
# / OBSERVATION_MAX_AGE_S here. Those are sim-only freshness widenings (see
# env_sim_in_the_loop.env); on the real robot the canonical tight defaults
# (~0.5 s / 0.2 s) must stand, or a genuinely stalled perception/inference
# stream gets masked. Their absence here is intentional and load-bearing.
